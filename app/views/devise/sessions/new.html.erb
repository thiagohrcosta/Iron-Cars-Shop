<div class="min-h-screen flex bg-slate-100">
  <div class="hidden lg:flex w-1/2 bg-gradient-to-br from-[#0A1F44] to-[#1E3A8A] text-white items-center">
    <div class="px-16">
      <%= image_tag "logo.png", alt: "Iron Cars Shop", style: "height: 120px; width: 320px; display: flex; justify-content: center; margin: auto" %>

      <h1 class="text-5xl font-bold leading-tight mb-6">
        Welcome back to <span class="text-blue-400">Iron Cars Shop</span>
      </h1>

      <p class="text-lg text-slate-200 mb-8">
        Access your marketplace dashboard, manage listings, and keep your negotiations moving.
      </p>

      <ul class="space-y-4 text-slate-200">
        <li class="flex items-center gap-3">
          <span class="text-blue-400">✔</span> Manage your active listings
        </li>
        <li class="flex items-center gap-3">
          <span class="text-blue-400">✔</span> Track buyer conversations
        </li>
        <li class="flex items-center gap-3">
          <span class="text-blue-400">✔</span> Close deals with confidence
        </li>
      </ul>
    </div>
  </div>

  <div class="flex w-full lg:w-1/2 items-center justify-center px-6 py-12">
    <div class="w-full max-w-md bg-white rounded-2xl shadow-xl p-10">
      <div class="mb-8 text-center">
        <h2 class="text-3xl font-bold text-[#0A1F44]">Log In</h2>
        <p class="text-slate-500 mt-2 text-sm">
          Continue your buying and selling journey
        </p>
      </div>

      <%= form_for(resource,
            as: resource_name,
            url: session_path(resource_name),
            html: { class: "space-y-6" }) do |f| %>

        <%= render "devise/shared/error_messages", resource: resource %>

        <div>
          <%= f.label :email, class: "block text-sm font-medium text-slate-700 mb-2" %>
          <%= f.email_field :email,
                autofocus: true,
                autocomplete: "email",
                class: "w-full rounded-lg border border-slate-300 px-4 py-3" %>
        </div>

        <div>
          <%= f.label :password, class: "block text-sm font-medium text-slate-700 mb-2" %>
          <%= f.password_field :password,
                autocomplete: "current-password",
                class: "w-full rounded-lg border border-slate-300 px-4 py-3" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <label class="flex items-center gap-3 text-sm text-slate-600">
            <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-slate-300 text-blue-600 focus:ring-blue-600" %>
            <span>Remember me</span>
          </label>
        <% end %>

        <%= f.submit "Log in",
              class: "w-full bg-blue-600 hover:bg-blue-700 text-white py-3 rounded-lg transition" %>
      <% end %>

      <div class="my-8 flex items-center">
        <div class="flex-grow border-t border-slate-300"></div>
        <span class="mx-4 text-sm text-slate-400">or</span>
        <div class="flex-grow border-t border-slate-300"></div>
      </div>

      <div class="text-center text-sm text-slate-500 space-y-3">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</div>
