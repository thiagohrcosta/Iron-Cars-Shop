<% vehicle_name = @vehicle&.full_name.presence || "BMW X5 2022 xDrive40i" %>
<% mileage = @vehicle&.mileage || 25_000 %>
<% transmission = @vehicle&.transmission&.humanize || "Automatic" %>
<% fuel_type = @vehicle&.fuel_type&.humanize || "Gasoline" %>
<% vehicle_price = (@vehicle&.price_cents.presence || 4_290_000) / 100.0 %>
<% location_city = @vehicle&.user&.address_city.presence || "Miami" %>
<% location_state = @vehicle&.user&.address_state.presence || "Florida" %>
<% photos = @vehicle&.photos&.attached? ? @vehicle.photos.limit(6) : [] %>

<section class="listing-page">
  <div class="listing-wrap">
    
    <div class="listing-grid">
      <main class="listing-main">
        <header class="listing-header">
          <h1><%= vehicle_name %></h1>
          <p>
            <%= number_with_delimiter(mileage) %> miles
            <span>•</span>
            <%= transmission %>
            <span>•</span>
            <%= fuel_type %>
          </p>
        </header>

        <section class="gallery-card">
          <div class="gallery-cover">
            <div class="gallery-nav-btn left">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
            </div>
            <%= image_tag(photos.any? ? url_for(photos.first) : "carbanner.png", alt: vehicle_name) %>
            <div class="gallery-nav-btn right">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
            </div>
            <span class="verified-pill">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
              Verified by Iron
            </span>
          </div>

          <div class="gallery-thumbs">
            <% if photos.any? %>
              <% photos.each_with_index do |photo, index| %>
                <%= image_tag url_for(photo), alt: vehicle_name, class: (index == 0 ? "active" : "") %>
              <% end %>
            <% else %>
              <% 5.times do |i| %>
                <%= image_tag "carbanner.png", alt: vehicle_name, class: (i == 0 ? "active" : "") %>
              <% end %>
            <% end %>
          </div>
        </section>

        <section class="spec-card">
          <div class="spec-tabs">
            <strong>Specifications</strong>
            <span>Classifications</span>
          </div>

          <div class="spec-grid">
            <div><b>Year</b><span><%= @vehicle&.year || 2022 %></span></div>
            <div><b>Exterior color</b><span><%= @vehicle&.exterior_color.presence || "Metallic" %></span></div>
            <div><b>Brand</b><span><%= @vehicle&.brand&.name || "BMW" %></span></div>
            <div><b>Interior color</b><span><%= @vehicle&.interior_color.presence || "White" %></span></div>
            <div><b>Model</b><span><%= @vehicle&.car_model&.name || "X5 xDrive40i" %></span></div>
            <div><b>VIN</b><span><%= @vehicle&.vin || "5UXCR6C00N9612245" %></span></div>
            <div><b>Version</b><span>SUV</span></div>
            <div><b>Avg consumption</b><span><%= @vehicle&.mpg_combined || 25 %> mpg</span></div>
            <div><b>Engine</b><span><%= @vehicle&.engine_description.presence || "3.0L Turbo" %></span></div>
            <div><b>Condition</b><span><%= @vehicle&.condition&.humanize || "Used" %></span></div>
            <div><b>Drivetrain</b><span><%= transmission %></span></div>
          </div>
        </section>

        <section class="about-card">
          <h2>About this vehicle</h2>
          <p>
            At Iron Cars we guarantee the best quality. The <%= vehicle_name %> has gone through a Premium experience with our detailed checking process. It has complete history, certifications from our experts and delivers total performance. Enjoy the extra confidence in your decision with our store's flexible options in the palm of your hand.
          </p>
        </section>

        <section class="history-card">
          <h2>Vehicle History</h2>
          <div class="history-row">
            <% if @similar_vehicles.any? %>
              <% @similar_vehicles.take(5).each do |vehicle| %>
                <article>
                  <%= image_tag(vehicle.photos.attached? ? url_for(vehicle.photos.first) : "carbanner.png", alt: vehicle.full_name) %>
                  <h3><%= vehicle.full_name.truncate(45) %></h3>
                  <p><%= number_to_currency(vehicle.price_cents / 100.0, precision: 0) %></p>
                </article>
              <% end %>
            <% else %>
              <article>
                  <%= image_tag "carbanner.png", alt: "Similar" %>
                  <h3>Mercedes-Benz GLC 2022</h3>
                  <p>$39,990</p>
              </article>
              <article>
                  <%= image_tag "carbanner.png", alt: "Similar" %>
                  <h3>Audi Q5 2021</h3>
                  <p>$37,500</p>
              </article>
              <article>
                  <%= image_tag "carbanner.png", alt: "Similar" %>
                  <h3>Volvo XC90 2020</h3>
                  <p>$39,600</p>
              </article>
              <article>
                  <%= image_tag "carbanner.png", alt: "Similar" %>
                  <h3>Porsche Cayenne 2021</h3>
                  <p>$44,500</p>
              </article>
              <article>
                  <%= image_tag "carbanner.png", alt: "Similar" %>
                  <h3>Acura RDX 2021</h3>
                  <p>$35,990</p>
              </article>
            <% end %>
          </div>
        </section>

        <div class="section-title-center">Similar Cars</div>
        <section class="calculator-card">
          <div class="calc-field">
            <label>Car value ($)</label>
            <select><option><%= number_to_currency(vehicle_price, precision: 0) %></option></select>
          </div>
          <div class="calc-field">
            <label>Down payment ($)</label>
            <select><option>$10,000</option></select>
          </div>
          <div class="calc-field">
            <label>Months</label>
            <select><option>48</option><option>60</option></select>
          </div>
          <button class="btn-simulate">Simulate now &rsaquo;</button>
        </section>

      </main>

      <aside class="listing-sidebar">
        <section class="price-card">
          <div class="price-top">
            <div>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78v0z"></path></svg>
              Favorites
            </div>
            <div>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg>
              Share
            </div>
          </div>

          <h3><%= vehicle_name %></h3>
          <p class="meta"><%= number_with_delimiter(mileage) %> miles - <%= transmission %> - <%= fuel_type %></p>
          <p class="meta"><%= location_city %>, <%= location_state %></p>

          <p class="value"><%= number_to_currency(vehicle_price, precision: 0) %></p>

          <button type="button" class="btn-primary">Buy now</button>
          <button type="button" class="btn-secondary">Talk to seller</button>

          <ul class="checks">
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <%= @vehicle&.owners_count == 1 ? "1 owner" : "Verified owner history" %>
            </li>
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <%= @vehicle&.clean_history? ? "Clean history" : "Detailed history" %>
            </li>
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <%= (@vehicle&.accident_count || 0).zero? ? "No accidents" : "No major accidents" %>
            </li>
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
              Extended warranty available
            </li>
          </ul>

          <div class="feature-box">
             <div class="feature-item">
               <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#667894" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
               Detailed checkup
             </div>
             <div class="feature-item">
               <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#667894" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
               Official report
             </div>
          </div>
          
          <button class="btn-delivery">
             <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1e365f" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
             Delivery available to other states
          </button>
        </section>

        <section class="dealer-card">
          <div class="dealer-map-wrap">
            <%= image_tag "sidebar.png", alt: "Dealer map" %>
            <div class="map-marker"></div>
          </div>
          <div class="dealer-info">
            <div class="dealer-header">
               <div class="dealer-icon">
                 <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
               </div>
               <div class="dealer-title-wrap">
                 <h4>Iron Cars Dealer Miami</h4>
                 <div class="rating">★★★★★ <span style="color:#617390">(300 vehicles)</span></div>
               </div>
            </div>
            <button type="button" class="btn-dealer">View dealer inventory</button>
          </div>
        </section>
      </aside>
    </div>
  </div>
</section>

