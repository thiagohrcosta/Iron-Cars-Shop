<% selected_brand_id = @vehicle.car_model&.brand_id %>
<div class="min-h-screen bg-slate-100 flex" data-controller="vehicle-form" data-vehicle-form-models-by-brand-value="<%= @models_by_brand.to_json %>">
  <aside
    class="hidden lg:flex lg:flex-col w-64 text-slate-100 bg-cover bg-center bg-no-repeat"
    style="background-image: url('<%= asset_path("sidebar.png") %>');"
  >
    <div class="p-6 border-b border-slate-800">
      <%= image_tag "logo.png", alt: "Iron Cars Shop", class: "h-14 w-auto" %>
    </div>

    <nav class="flex-1 px-4 py-6 space-y-2 text-sm">
      <a href="#" class="block px-4 py-2 rounded-lg hover:bg-slate-800">Dashboard</a>
      <a href="#" class="block px-4 py-2 rounded-lg hover:bg-slate-800">My Listings</a>
      <a href="#" class="block px-4 py-2 rounded-lg hover:bg-slate-800">Offers</a>
      <a href="#" class="block px-4 py-2 rounded-lg hover:bg-slate-800">Messages</a>
      <a href="#" class="block px-4 py-2 rounded-lg hover:bg-slate-800">Sales</a>
      <a href="#" class="block px-4 py-2 rounded-lg hover:bg-slate-800">Analytics</a>
      <a href="#" class="block px-4 py-2 rounded-lg hover:bg-slate-800">Settings</a>
    </nav>

    <div class="px-4 pb-6">
      <a href="<%= new_user_vehicle_path %>" class="block text-center bg-blue-600 hover:bg-blue-700 text-white py-3 rounded-lg">+ Sell Your Car</a>
    </div>

    <div class="px-4 pb-6 text-sm text-slate-300">
      <p class="font-semibold text-white"><%= current_user.full_name.presence || current_user.email %></p>
      <p>Seller</p>
    </div>
  </aside>

  <div class="flex-1 flex flex-col">
    <header class="bg-white border-b border-slate-200 px-6 py-5 flex flex-wrap gap-4 items-center justify-between">
      <div>
        <h1 class="text-4xl font-semibold text-slate-800">Sell Your Car</h1>
        <p class="text-sm text-slate-500">Fill in the details below. We'll fetch specs automatically.</p>
      </div>

      <div class="flex gap-3">
        <button type="button" class="px-5 py-2.5 rounded-lg border border-slate-300 text-slate-700 bg-white">Save Draft</button>
      </div>
    </header>

    <div class="bg-white border-b border-slate-200 px-6 py-4">
      <div class="flex flex-wrap items-center gap-4 text-sm font-semibold text-slate-500">
        <div class="flex items-center gap-2 text-blue-600">
          <span class="w-6 h-6 rounded-full bg-blue-600 text-white flex items-center justify-center text-xs">1</span>
          Vehicle Info
        </div>
        <div>2 Photos</div>
        <div>3 Pricing & Details</div>
        <div>4 Review & Publish</div>
      </div>
    </div>

    <main class="p-6">
      <%= form_with model: @vehicle, url: user_vehicles_path, class: "grid grid-cols-1 2xl:grid-cols-3 gap-6" do |f| %>
        <div class="2xl:col-span-2 space-y-6">
          <% if @vehicle.errors.any? %>
            <div class="bg-red-50 border border-red-200 rounded-xl p-4 text-red-700">
              <p class="font-semibold mb-2">Please fix the following:</p>
              <ul class="list-disc list-inside text-sm space-y-1">
                <% @vehicle.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">
            <section class="xl:col-span-2 bg-white rounded-xl border border-slate-200 p-5 space-y-5">
              <h2 class="text-3xl font-semibold text-slate-900">Vehicle Info</h2>

              <div>
                <%= f.label :vin, "VIN Number", class: "block text-sm font-semibold text-slate-700 mb-2" %>
                <div class="flex flex-wrap gap-2">
                  <%= f.text_field :vin,
                        placeholder: "Enter 17-digit VIN",
                        maxlength: 17,
                        minlength: 17,
                        required: true,
                        pattern: "\\d{17}",
                        class: "flex-1 min-w-[16rem] border border-slate-300 rounded-lg px-4 py-2.5",
                        data: {
                          vehicle_form_target: "vin",
                          action: "input->vehicle-form#checkVin input->vehicle-form#updatePreview"
                        } %>
                  <button type="button" data-action="click->vehicle-form#checkVin" class="bg-blue-600 hover:bg-blue-700 text-white rounded-lg px-5 py-2.5">Check VIN</button>
                </div>
                <p class="mt-2 text-sm text-slate-500" data-vehicle-form-target="vinStatus">VIN must contain exactly 17 digits.</p>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div>
                  <label class="block text-sm font-medium text-slate-700 mb-2">Brand *</label>
                  <select class="w-full border border-slate-300 rounded-lg px-4 py-2.5"
                          data-vehicle-form-target="brand"
                          data-action="change->vehicle-form#brandChanged change->vehicle-form#updatePreview">
                    <option value="">Select Brand</option>
                    <% @brands.each do |brand| %>
                      <option value="<%= brand.id %>" <%= "selected" if selected_brand_id == brand.id %>><%= brand.name %></option>
                    <% end %>
                  </select>
                </div>

                <div>
                  <%= f.label :car_model_id, "Model *", class: "block text-sm font-medium text-slate-700 mb-2" %>
                  <%= f.select :car_model_id,
                        options_for_select(@models_by_brand.fetch(selected_brand_id, []), f.object.car_model_id),
                        { include_blank: "Select Model" },
                        {
                          class: "w-full border border-slate-300 rounded-lg px-4 py-2.5",
                          required: true,
                          data: {
                            vehicle_form_target: "model",
                            action: "change->vehicle-form#updatePreview"
                          }
                        } %>
                </div>

                <div>
                  <%= f.label :year, "Year *", class: "block text-sm font-medium text-slate-700 mb-2" %>
                  <%= f.select :year,
                        options_for_select(@year_options, f.object.year),
                        {},
                        {
                          class: "w-full border border-slate-300 rounded-lg px-4 py-2.5",
                          required: true,
                          data: {
                            vehicle_form_target: "year",
                            action: "change->vehicle-form#updatePreview"
                          }
                        } %>
                </div>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <%= f.label :mileage, class: "block text-sm font-medium text-slate-700 mb-2" %>
                  <%= f.number_field :mileage,
                        min: 0,
                        required: true,
                        class: "w-full border border-slate-300 rounded-lg px-4 py-2.5",
                        data: {
                          vehicle_form_target: "mileage",
                          action: "input->vehicle-form#updatePreview"
                        } %>
                </div>

                <div>
                  <%= f.label :condition, class: "block text-sm font-medium text-slate-700 mb-2" %>
                  <%= f.select :condition,
                        Vehicle.conditions.keys.map { |value| [ value.humanize, value ] },
                        {},
                        { class: "w-full border border-slate-300 rounded-lg px-4 py-2.5" } %>
                </div>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <%= f.label :exterior_color, class: "block text-sm font-medium text-slate-700 mb-2" %>
                  <%= f.text_field :exterior_color, class: "w-full border border-slate-300 rounded-lg px-4 py-2.5" %>
                </div>

                <div>
                  <%= f.label :interior_color, class: "block text-sm font-medium text-slate-700 mb-2" %>
                  <%= f.text_field :interior_color, class: "w-full border border-slate-300 rounded-lg px-4 py-2.5" %>
                </div>
              </div>

              <div class="grid grid-cols-2 lg:grid-cols-5 gap-3">
                <div>
                  <%= f.label :transmission, class: "block text-sm font-medium text-slate-700 mb-2" %>
                  <%= f.select :transmission,
                        Vehicle.transmissions.keys.map { |value| [ value.humanize, value ] },
                        { include_blank: "Select" },
                        {
                          class: "w-full border border-slate-300 rounded-lg px-3 py-2.5",
                          data: {
                            vehicle_form_target: "transmission",
                            action: "change->vehicle-form#updatePreview"
                          }
                        } %>
                </div>

                <div>
                  <%= f.label :fuel_type, "Fuel Type", class: "block text-sm font-medium text-slate-700 mb-2" %>
                  <%= f.select :fuel_type,
                        Vehicle.fuel_types.keys.map { |value| [ value.humanize, value ] },
                        { include_blank: "Select" },
                        {
                          class: "w-full border border-slate-300 rounded-lg px-3 py-2.5",
                          data: {
                            vehicle_form_target: "fuelType",
                            action: "change->vehicle-form#updatePreview"
                          }
                        } %>
                </div>

                <div>
                  <%= f.label :drivetrain, class: "block text-sm font-medium text-slate-700 mb-2" %>
                  <%= f.select :drivetrain,
                        Vehicle.drivetrains.keys.map { |value| [ value.humanize, value ] },
                        { include_blank: "Select" },
                        {
                          class: "w-full border border-slate-300 rounded-lg px-3 py-2.5",
                          data: {
                            vehicle_form_target: "drivetrain",
                            action: "change->vehicle-form#updatePreview"
                          }
                        } %>
                </div>

                <div>
                  <%= f.label :doors, class: "block text-sm font-medium text-slate-700 mb-2" %>
                  <%= f.select :doors,
                        options_for_select((2..6).map { |value| [ value, value ] }, f.object.doors),
                        { include_blank: "Select" },
                        {
                          class: "w-full border border-slate-300 rounded-lg px-3 py-2.5",
                          data: {
                            vehicle_form_target: "doors",
                            action: "change->vehicle-form#updatePreview"
                          }
                        } %>
                </div>

                <div>
                  <%= f.label :seats, class: "block text-sm font-medium text-slate-700 mb-2" %>
                  <%= f.select :seats,
                        options_for_select((2..8).map { |value| [ value, value ] }, f.object.seats),
                        { include_blank: "Select" },
                        {
                          class: "w-full border border-slate-300 rounded-lg px-3 py-2.5",
                          data: {
                            vehicle_form_target: "seats",
                            action: "change->vehicle-form#updatePreview"
                          }
                        } %>
                </div>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div>
                  <%= f.label :title_status, "Title Status", class: "block text-sm font-medium text-slate-700 mb-2" %>
                  <%= f.select :title_status,
                        Vehicle.title_statuses.keys.map { |value| [ value.humanize, value ] },
                        {},
                        {
                          class: "w-full border border-slate-300 rounded-lg px-3 py-2.5",
                          data: {
                            vehicle_form_target: "titleStatus",
                            action: "change->vehicle-form#updatePreview"
                          }
                        } %>
                </div>

                <div>
                  <%= f.label :currency, class: "block text-sm font-medium text-slate-700 mb-2" %>
                  <%= f.select :currency,
                        Vehicle.currencies.keys.map { |value| [ value.upcase, value ] },
                        {},
                        { class: "w-full border border-slate-300 rounded-lg px-3 py-2.5" } %>
                </div>

                <div>
                  <%= f.label :price, "Price", class: "block text-sm font-medium text-slate-700 mb-2" %>
                  <%= f.number_field :price,
                        min: 0,
                        step: 0.01,
                        class: "w-full border border-slate-300 rounded-lg px-3 py-2.5",
                        data: {
                          vehicle_form_target: "price",
                          action: "input->vehicle-form#updatePreview"
                        } %>
                </div>
              </div>

              <div>
                <%= f.label :engine_description, class: "block text-sm font-medium text-slate-700 mb-2" %>
                <%= f.text_field :engine_description, class: "w-full border border-slate-300 rounded-lg px-4 py-2.5" %>
              </div>
            </section>

            <section class="bg-white rounded-xl border border-slate-200 p-5 space-y-4">
              <h2 class="text-3xl font-semibold text-slate-900">Vehicle Photos</h2>

              <label class="block border-2 border-dashed border-blue-300 bg-blue-50/40 rounded-xl p-6 text-center text-slate-600 cursor-pointer">
                <span class="font-semibold text-slate-800">Upload Photos</span><br>
                <span>Drag & drop or <span class="text-blue-600">browse</span></span><br>
                <span class="text-xs text-slate-500">Max 20 photos</span>
                <%= f.file_field :photos,
                      multiple: true,
                      class: "hidden",
                      data: {
                        vehicle_form_target: "photos",
                        action: "change->vehicle-form#photosChanged"
                      } %>
              </label>

              <p class="text-sm text-slate-500" data-vehicle-form-target="photoCount">No photos selected</p>

              <div class="grid grid-cols-2 gap-2" data-vehicle-form-target="photoGallery"></div>
            </section>
          </div>

          <div class="flex justify-end gap-3">
            <button type="button" class="px-5 py-2.5 rounded-lg border border-slate-300 bg-white text-slate-700">Save Draft</button>
            <%= f.submit "Next: Photos →", class: "px-6 py-2.5 rounded-lg bg-blue-600 hover:bg-blue-700 text-white" %>
          </div>
        </div>

        <aside class="space-y-4">
          <section class="bg-white rounded-xl border border-slate-200 overflow-hidden">
            <img src="https://images.unsplash.com/photo-1619767886558-efdc259cde1a"
                 class="w-full h-52 object-cover"
                 data-vehicle-form-target="previewImage">

            <div class="p-5 space-y-2">
              <h3 class="text-3xl font-semibold text-slate-900">Listing Preview</h3>
              <p class="text-5xl font-bold text-slate-900" data-vehicle-form-target="previewPrice">$0</p>
              <p class="text-3xl text-slate-700" data-vehicle-form-target="previewName">Year Brand Model</p>
              <p class="text-3xl text-slate-600" data-vehicle-form-target="previewMileage">0 miles</p>
              <p class="text-3xl text-slate-600" data-vehicle-form-target="previewSpecs">Transmission · Fuel · Drivetrain · Doors · Seats</p>
              <p class="text-3xl text-slate-700" data-vehicle-form-target="previewTitle">Clean Title</p>
            </div>
          </section>
        </aside>
      <% end %>
    </main>
  </div>
</div>
