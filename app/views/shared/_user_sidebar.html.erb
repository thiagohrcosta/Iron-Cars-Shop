<aside
  class="hidden lg:flex lg:flex-col w-64 text-slate-100 bg-cover bg-center bg-no-repeat"
  style="background-image: url('<%= asset_path("sidebar.png") %>');"
>
  <div class="p-6 border-b border-slate-800">
    <%= image_tag "logo.png", alt: "Iron Cars Shop", class: "h-14 w-auto" %>
  </div>

  <nav class="flex-1 px-4 py-6 space-y-2 text-sm">
    <a href="<%= user_dashboard_path %>" class="block px-4 py-2 rounded-lg hover:bg-slate-800 <%= 'bg-slate-800/80 font-semibold' if current_page?(user_dashboard_path) rescue false %>">Dashboard</a>
    <a href="<%= user_vehicles_path %>" class="block px-4 py-2 rounded-lg hover:bg-slate-800 <%= 'bg-slate-800/80 font-semibold' if current_page?(user_vehicles_path) rescue false %>">My Listings</a>
    <a href="<%= user_negotiations_path %>" class="block px-4 py-2 rounded-lg hover:bg-slate-800 <%= 'bg-slate-800/80 font-semibold' if current_page?(user_negotiations_path) rescue false %>">Offers</a>
    <a href="<%= cars_path %>" class="block px-4 py-2 rounded-lg hover:bg-slate-800 <%= 'bg-slate-800/80 font-semibold' if current_page?(cars_path) rescue false %>">Sales</a>
    <a href="#" class="block px-4 py-2 rounded-lg hover:bg-slate-800">Analytics</a>
    <a href="#" class="block px-4 py-2 rounded-lg hover:bg-slate-800">Settings</a>
  </nav>

  <div class="px-4 pb-6">
    <a href="<%= new_user_vehicle_path %>" class="block text-center bg-blue-600 hover:bg-blue-700 text-white py-3 rounded-lg">+ Sell Your Car</a>
  </div>

  <div class="px-4 pb-6 text-sm text-slate-300">
    <p class="font-semibold text-white"><%= current_user.full_name.presence || current_user.email %></p>
    <p>Seller</p>
  </div>
</aside>